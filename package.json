{
  "name": "didibudget-frontend",
  "version": "1.16.2",
  "description": "didibudget-frontend",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.14.x"
  },
  "dependencies": {
    "@apollo/client": "3.14.1",
    "bootstrap": "5.1.3",
    "graphql": "16.14.0",
    "graphql-tag": "2.12.6",
    "jwt-decode": "4.0.0",
    "moment": "2.30.1",
    "prop-types": "15.8.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-icons": "4.12.0",
    "react-router": "6.30.4",
    "react-router-dom": "6.30.4",
    "react-toggle": "4.1.3",
    "react-widgets": "4.6.1",
    "react-widgets-moment": "4.0.30",
    "reactstrap": "9.2.3",
    "recharts": "3.8.1"
  },
  "scripts": {
    "lint": "eslint --ext .js ./src",
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "keywords": [
    "budget",
    "React",
    "GraphQL",
    "Apollo",
    "client"
  ],
  "author": "Dídac García (https://didaquis.github.io/)",
  "license": "MIT",
  "eslintConfig": {
    "extends": "react-app",
    "plugins": [
      "no-lenght"
    ],
    "globals": {
      "vi": "readonly"
    },
    "rules": {
      "no-lenght/no-lenght": "error",
      "semi": [
        "warn",
        "never"
      ],
      "quotes": [
        "warn",
        "single"
      ],
      "no-return-await": "error",
      "curly": "error"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "5.17.0",
    "@testing-library/react": "14.3.1",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/coverage-v8": "3.2.7",
    "eslint-config-react-app": "7.0.1",
    "eslint-plugin-no-lenght": "1.0.2-0",
    "husky": "9.1.7",
    "jsdom": "26.1.0",
    "vite": "6.4.3",
    "vitest": "3.2.7"
  }
}
